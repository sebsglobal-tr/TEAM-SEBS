{
  "name": "worktrack-agent",
  "version": "1.0.0",
  "description": "WorkTrack Desktop Agent - Transparent work session tracking",
  "main": "dist/main/index.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron dist/main/index.js",
    "pack": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  },
  "build": {
    "appId": "com.worktrack.agent",
    "productName": "WorkTrack Agent",
    "directories": { "output": "release" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" }
  }
}
